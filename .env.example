# ── Rift Hunter · OANDA live trading ─────────────────────────────────────────
# Copy to ".env" and fill in. NEVER commit your real .env (it's gitignored).

# Your OANDA v20 API token (Account → "Manage API Access" → Generate).
OANDA_API_TOKEN=

# The OANDA account to trade, e.g. 001-001-1234567-001
OANDA_ACCOUNT_ID=

# "practice" (demo, fxpractice) or "live" (real money, fxtrade).
# Defaults to practice. Only set "live" when you have backtested and validated.
OANDA_ENVIRONMENT=practice

# Master safety switch. "false" = monitoring only (reads account/trades/prices).
# Set "true" to allow Henry / the UI to place and close real orders.
ALLOW_TRADING=false

# ── Risk management ───────────────────────────────────────────────────────────
# Maximum daily drawdown % before autonomous trading is suspended.
# Henry will refuse to open new positions if NAV has fallen this % from balance.
MAX_DD_PCT=5

# Default TP/SL brackets (% from entry price) when ATR is unavailable.
# ATR-based brackets (3× ATR take-profit, 1.5× ATR stop-loss) are used when
# the /api/signals endpoint has live ATR data — these are the fallbacks.
# Current ratio: 1.2 / 0.4 = 3:1 reward-to-risk.
DEFAULT_TP_PCT=1.2
DEFAULT_SL_PCT=0.4

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787
CORS_ORIGIN=*

# ── Frontend ──────────────────────────────────────────────────────────────────
# Where the browser reaches the proxy above. Leave default for local dev.
VITE_API_BASE=http://localhost:8787
